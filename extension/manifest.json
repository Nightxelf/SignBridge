{
  "manifest_version": 3,
  "name": "SignBridge Overlay",
  "description": "Live sign language captions for video calls.",
  "version": "0.1.0",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ],
  "action": {
    "default_title": "SignBridge",
    "default_popup": "index.html"
  }
}
